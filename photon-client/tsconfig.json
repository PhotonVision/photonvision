{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "components.d.ts", "vite.config.ts", "playwright.config.ts", "src/**/*", "src/**/*.vue", "tests/**/*"],
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "strict": true,
    "removeComments": true,
    "sourceMap": true,
    "module": "ESNext",
    "types": ["node", "unplugin-icons/types/vue"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
}
